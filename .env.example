# Copy to .env and fill in. Architecture Rule 5: all hosts/ports/keys live here,
# never hardcoded in application code.

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Postgres (enterprise data mart) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=password
DB_NAME=enterprise_dw

# --- Celery / Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
# Optional explicit overrides (otherwise derived from REDIS_HOST/PORT):
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- R sandbox ---
# Host-run worker reaching the docker sandbox: http://localhost:8001
# Worker running inside the compose network: http://r_sandbox:8001
R_SANDBOX_URL=http://localhost:8001
R_SANDBOX_TIMEOUT=150

# --- Local data / orchestration ---
DATA_DIR=data
MAX_RETRIES=3

# --- Kafka / event-driven layer (Phase 3) ---
# Local dev: Redpanda's external listener. Deploy: managed-Kafka bootstrap.
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_TOPIC=order-events
KAFKA_CONSUMER_GROUP=causal-consumer
# Events ingested before one causal analysis auto-fires.
KAFKA_TRIGGER_THRESHOLD=500
# Auth: leave as PLAINTEXT locally. For managed Kafka (e.g. Upstash) set:
#   KAFKA_SECURITY_PROTOCOL=SASL_SSL
#   KAFKA_SASL_MECHANISM=SCRAM-SHA-256
#   KAFKA_SASL_USERNAME=...
#   KAFKA_SASL_PASSWORD=...
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

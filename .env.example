# Copy to .env and fill in. Architecture Rule 5: all hosts/ports/keys live here,
# never hardcoded in application code.

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Postgres (enterprise data mart) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=password
DB_NAME=enterprise_dw

# --- Celery / Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
# Optional explicit overrides (otherwise derived from REDIS_HOST/PORT):
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- R sandbox ---
# Host-run worker reaching the docker sandbox: http://localhost:8001
# Worker running inside the compose network: http://r_sandbox:8001
R_SANDBOX_URL=http://localhost:8001
R_SANDBOX_TIMEOUT=150

# --- Local data / orchestration ---
DATA_DIR=data
MAX_RETRIES=3

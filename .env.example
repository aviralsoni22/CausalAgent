# Copy to .env and fill in. Architecture Rule 5: all hosts/ports/keys live here,
# never hardcoded in application code.

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Observability (Phase 4): LangSmith LLM tracing ---
# OFF by default. Traces carry the schema, generated SQL, R scripts and stat
# outputs to LangSmith's hosted store (raw DB rows are never traced). Turn on
# only in an environment where shipping that off-box is acceptable.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=causalagent
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com  # EU: https://eu.api.smith.langchain.com

# MLflow causal-run tracking. OFF by default.
# MLFLOW_TRACKING_URI backends:
#   ./mlruns        local file store (default; zero setup, works with the skinny
#                   client). View: uvx mlflow ui --backend-store-uri ./mlruns
#   http(s)://host  remote tracking server — the deployment/K8s path (skinny
#                   client talks REST, no DB deps needed)
#   sqlite:///x.db  needs `alembic` installed (NOT bundled with mlflow-skinny)
MLFLOW_TRACKING=false
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT=causalagent

# --- Postgres (enterprise data mart) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=password
DB_NAME=enterprise_dw

# --- Celery / Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
# Optional explicit overrides (otherwise derived from REDIS_HOST/PORT):
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- R sandbox ---
# Host-run worker reaching the docker sandbox: http://localhost:8001
# Worker running inside the compose network: http://r_sandbox:8001
R_SANDBOX_URL=http://localhost:8001
R_SANDBOX_TIMEOUT=150

# --- Local data / orchestration ---
DATA_DIR=data
MAX_RETRIES=3

# --- Ingress auth + rate limiting ---
# INGRESS_API_KEYS: comma-separated set of accepted X-API-Key values. Empty =
# OPEN ingress (local dev; the API logs a warning). Set it before exposing the
# service. INGRESS_API_KEY: the single key the Discord bot / eval scripts present.
INGRESS_API_KEYS=
INGRESS_API_KEY=
# Per-caller budget (keyed by API key, else client IP). Set RATE_LIMIT_REQUESTS<=0
# to disable.
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_S=60

# --- Kafka / event-driven layer (Phase 3) ---
# Local dev: Redpanda's external listener. Deploy: managed-Kafka bootstrap.
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_TOPIC=order-events
KAFKA_CONSUMER_GROUP=causal-consumer
# Events ingested before one causal analysis auto-fires.
KAFKA_TRIGGER_THRESHOLD=500
# Auth: leave as PLAINTEXT locally. For managed Kafka (e.g. Upstash) set:
#   KAFKA_SECURITY_PROTOCOL=SASL_SSL
#   KAFKA_SASL_MECHANISM=SCRAM-SHA-256
#   KAFKA_SASL_USERNAME=...
#   KAFKA_SASL_PASSWORD=...
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
# --- Discord demo adapter ---
# Put the REAL token in .env (git-ignored), NEVER here. Create a bot at
# https://discord.com/developers/applications, invite it with the `bot` +
# `applications.commands` scopes, and copy its token.
DISCORD_BOT_TOKEN=your-discord-bot-token-here
# Server (guild) id for instant slash-command sync (else global, ~1h). Enable
# Developer Mode, right-click the server, Copy Server ID.
DISCORD_GUILD_ID=
# Where the bot / eval scripts reach the API (host: localhost; in-compose: api:8000).
API_BASE_URL=http://localhost:8000
# BOT_POLL_TIMEOUT_S=720
# BOT_POLL_INTERVAL_S=2.0

# --- Demo simulation routes ---
# /sim emit/truth/storefront — unauthenticated + state-changing, OFF by default.
# The local compose stack sets it to 1; never enable in a real-data deployment.
ENABLE_SIM_ROUTES= 